{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-host",
      "displayName": "Headless Linux host (i386)",
      "description": "LH-P6: GCC/Clang -m32 build of the dedicated host for Linux containers. Requires g++-multilib (32-bit libstdc++/libc/pthread).",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-host",
      "configurePreset": "linux-host"
    }
  ]
}

