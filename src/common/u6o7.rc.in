/////////////////////////////////////////////////////////////////////////////
// Icons
//
// Paths are written here by CMake's configure_file() and point at the
// rasterized .ico files in ${CMAKE_BINARY_DIR}/generated/icons/, which
// are themselves built from assets/images/icon.png by tools/build_icon.ps1.
//
// Lowest-ID icon wins for Explorer's "file icon" view, so keep IDI_U6O7
// numerically below IDI_SMALL in Resource.h.
IDI_U6O7  ICON "@GENERATED_ICON_U6O7_RC@"
IDI_SMALL ICON "@GENERATED_ICON_SMALL_RC@"
/////////////////////////////////////////////////////////////////////////////
// Menu
//
IDC_U6O7 MENU
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                IDM_EXIT
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About ...",           IDM_ABOUT
    END
END
/////////////////////////////////////////////////////////////////////////////
// Accelerator
//
IDC_U6O7 ACCELERATORS
BEGIN
    "?",            IDM_ABOUT,              ASCII,  ALT
    "/",            IDM_ABOUT,              ASCII,  ALT
END
/////////////////////////////////////////////////////////////////////////////
// Dialog
//
IDD_ABOUTBOX DIALOG   22, 17, 230, 75
STYLE DS_MODALFRAME | WS_CAPTION | WS_SYSMENU
CAPTION "About"
FONT 8, "System"
BEGIN
    ICON            IDI_U6O7,IDC_MYICON,14,9,16,16
    LTEXT           "Ultima VI Online",IDC_STATIC,49,10,119,8,SS_NOPREFIX
    LTEXT           "Copyright (C) 2026",IDC_STATIC,49,20,119,8
    DEFPUSHBUTTON   "OK",IDOK,195,6,30,11,WS_GROUP
END
